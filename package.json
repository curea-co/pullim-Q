{
  "name": "pullim-q-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:q": "bun --filter @pullim-q/q dev",
    "dev:backend": "bun --filter @pullim-q/backend dev",
    "build": "turbo build",
    "build:q": "bun --filter @pullim-q/q build",
    "build:backend": "bun --filter @pullim-q/backend build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.7.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "bun@1.3.12"
}
