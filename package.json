    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-katex": "^3.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.4.0",
