{
  "$source": "pullim-q.vercel.app/q — extracted via computed styles + visual inspection on 2026-05-19",
  "color": {
    "brand": {
      "primary": "#2854D8",
      "primary-hover": "#1D3FA8",
      "primary-soft": "#3B6FF6",
      "primary-50": "#DCE6FF",
      "primary-100": "#DAE3FB",
      "on-primary": "#FFFFFF",
      "theme-meta": "#3B6FF6"
    },
    "accent": {
      "warning": "#F59E0B",
      "warning-soft-bg": "#FFF7E6",
      "warning-text": "#5C6B0A",
      "danger": "#E5484D",
      "danger-soft-bg": "#FDECEC",
      "success": "#12B26B",
      "success-soft-bg": "#E6F8EF",
      "lime-highlight": "#E6FF4C"
    },
    "neutral": {
      "bg": "#FFFFFF",
      "bg-muted": "#F5F7FB",
      "surface": "#EDF0F5",
      "surface-2": "#F5F7FB",
      "border": "#DDE2EC",
      "border-strong": "#B7BDCD",
      "text": "#121627",
      "text-secondary": "#4A536A",
      "text-tertiary": "#6B7489",
      "text-quaternary": "#97A0B4",
      "text-on-primary": "#FFFFFF"
    }
  },
  "typography": {
    "fontFamily": "\"Pretendard Variable\", Pretendard, -apple-system, system-ui, Roboto, sans-serif",
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "size": {
      "xxs": "10px",
      "xs": "11px",
      "sm": "12px",
      "base": "14px",
      "md": "16px",
      "lg": "24px"
    },
    "lineHeight": {
      "tight": "20px",
      "base": "24px",
      "heading": "32px"
    },
    "scale-note": "Page uses a very tight scale: 10/11/12/14/16/24 — almost no 18/20/28/32/40. H1 maxes at 24px; H3+H4 collapse into 16/14."
  },
  "spacing": {
    "$note": "Inferred from observed paddings/gaps in cards, buttons, list items",
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "section-gap": "24px"
  },
  "radius": {
    "sm": "8px",
    "md": "14px",
    "lg": "18px",
    "xl": "20px",
    "2xl": "26px",
    "pill": "9999px",
    "$dominant": ["14px (cards, buttons)", "20px (hero, large cards)", "9999px (avatars, chips, FAB)"]
  },
  "shadow": {
    "$note": "Shadows are extremely restrained — only 3 distinct shadows on the homepage. The look is flat-with-borders, not elevation-driven.",
    "none": "none",
    "card": "0 1px 0 rgba(18,22,39,0.03) (mostly border-only)",
    "elevated": "0 20px 25px -5px rgba(0,0,0,0.10), 0 8px 10px -6px rgba(0,0,0,0.10)",
    "fab": "0 10px 15px -3px rgba(40,84,216,0.30), 0 4px 6px -4px rgba(40,84,216,0.30)",
    "focus-ring-warning": "0 0 0 1px rgba(245,158,11,0.2)"
  },
  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1440px",
    "$observed": "Sidebar nav swaps to bottom tab bar somewhere between 768px and 1024px (likely md/lg)."
  },
  "component": {
    "button": {
      "primary": { "bg": "#2854D8", "color": "#FFFFFF", "radius": "14px", "fontWeight": 700 },
      "secondary": { "bg": "#FFFFFF", "color": "#2854D8", "border": "1px solid #DAE3FB", "radius": "14px" },
      "warning-cta": { "bg": "#F59E0B", "color": "#FFFFFF", "radius": "14px" },
      "fab": { "bg": "#2854D8", "color": "#FFFFFF", "radius": "9999px", "shadow": "elevated-blue-glow", "label": "AI에게 묻기" }
    },
    "card": { "bg": "#FFFFFF", "border": "1px solid #DDE2EC", "radius": "14px / 20px", "padding": "16-24px" },
    "chip": { "radius": "9999px", "fontSize": "11px", "fontWeight": 600 },
    "hero": { "bg": "linear-gradient(#2854D8 → #3B6FF6)", "color": "#FFFFFF", "radius": "20px" }
  },
  "iconography": {
    "library-likely": "lucide-react",
    "stroke-style": "outline 1.5–2px"
  }
}
